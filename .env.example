# XPayLabs-x402 Integration Test Configuration
#
# Prerequisites:
#   1. Create a copy of this file named .env
#   2. Get a Base Sepolia testnet wallet with USDC from https://faucet.circle.com/
#   3. Replace the placeholder below with your private key
#   4. Set TEST_URL to your x402-enabled seller API endpoint

# Your EVM private key (with or without 0x prefix)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# x402-enabled API endpoint (the seller's server that accepts x402 payments)
# The seller sets their own收款地址 (payTo) and amount in the 402 response
# Examples:
#   - Self-hosted: https://your-api.com/paid-endpoint
#   - Third-party: ask your seller for their x402 API URL
TEST_URL=https://your-x402-seller.com/api
